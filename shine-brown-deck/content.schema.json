{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["cta", "slides"],
  "additionalProperties": false,
  "properties": {
    "cta": { "type": "object", "required": ["label","href"], "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "maxLength": 24, "description": "Sticky bottom CTA text." },
        "href": { "type": "string", "format": "uri-reference", "description": "Cart permalink or product URL." } } },
    "slides": { "type": "array", "minItems": 1, "maxItems": 8, "description": "Full-bleed 9:16 swipe cards.",
      "items": { "type": "object", "required": ["headline"], "additionalProperties": false,
        "properties": {
          "image": { "type": "string", "description": "Full-bleed background image path (assets/...)." },
          "headline": { "type": "string", "maxLength": 60, "description": "Big overlay headline." },
          "sub": { "type": "string", "maxLength": 120, "description": "Optional line under the headline." } } } }
  }
}
